{
  "schemaVersion": 4,
  "systemSkills": [
    {
      "packageDir": "myopenpanels-panels",
      "id": "myopenpanels-panels",
      "name": "MyOpenPanels Panels",
      "source": "builtin",
      "appliesTo": ["canvas", "wiki", "writing"],
      "taskTypes": [],
      "requiresCommands": [],
      "loadWhen": [
        "Before reading or changing content through a MyOpenPanels Canvas, Wiki, or Writing panel."
      ],
      "tokens": "short",
      "procedures": [
        {
          "key": "panel.canvas.selection.read",
          "description": "Read the current explicit Canvas selection or its empty state.",
          "panelKind": "canvas",
          "references": [
            "references/canvas-contract.md",
            "references/canvas-selection.md"
          ],
          "selectionPolicy": "active-detail",
          "commandIntents": ["panel.selection.read"]
        },
        {
          "key": "panel.canvas.selection.export",
          "description": "Export the explicit Canvas selection to a user-requested file.",
          "panelKind": "canvas",
          "references": [
            "references/canvas-contract.md",
            "references/canvas-selection-export.md"
          ],
          "selectionPolicy": "explicit-detail",
          "commandIntents": ["panel.selection.read", "canvas.selection.export"]
        },
        {
          "key": "panel.canvas.image.insert",
          "description": "Insert an existing bitmap file into the Project Canvas.",
          "panelKind": "canvas",
          "references": [
            "references/canvas-contract.md",
            "references/canvas-image-insert.md"
          ],
          "selectionPolicy": "none",
          "commandIntents": ["canvas.image.create"]
        },
        {
          "key": "panel.canvas.image.generate",
          "description": "Generate a new bitmap and place it into the Project Canvas.",
          "panelKind": "canvas",
          "references": [
            "references/canvas-contract.md",
            "references/canvas-image-generation.md"
          ],
          "selectionPolicy": "optional-detail",
          "commandIntents": [
            "canvas.image.generate",
            "operation.complete",
            "operation.fail",
            "operation.cancel"
          ]
        },
        {
          "key": "panel.canvas.image.edit",
          "description": "Edit, restyle, or redraw an explicitly selected Canvas image.",
          "panelKind": "canvas",
          "references": [
            "references/canvas-contract.md",
            "references/canvas-image-edit.md"
          ],
          "selectionPolicy": "explicit-detail",
          "commandIntents": [
            "panel.selection.read",
            "canvas.image.generate",
            "operation.complete",
            "operation.fail",
            "operation.cancel"
          ]
        },
        {
          "key": "panel.wiki.knowledge.query",
          "description": "Answer from selected Wiki knowledge or selected Wiki documents.",
          "panelKind": "wiki",
          "references": [
            "references/wiki-contract.md",
            "references/wiki-knowledge-context.md"
          ],
          "selectionPolicy": "optional-detail",
          "commandIntents": [
            "panel.selection.read",
            "wiki.space.materialize",
            "wiki.page.search",
            "wiki.page.list",
            "wiki.page.read",
            "wiki.raw.read",
            "wiki.document.read"
          ]
        },
        {
          "key": "panel.wiki.raw.import",
          "description": "Import a source file or Markdown text as a Wiki Raw Document.",
          "panelKind": "wiki",
          "references": [
            "references/wiki-contract.md",
            "references/wiki-import-raw-document.md"
          ],
          "selectionPolicy": "none",
          "commandIntents": ["wiki.raw.create"]
        },
        {
          "key": "panel.wiki.document.read",
          "description": "Read a generated document selected or named by the user.",
          "panelKind": "wiki",
          "references": [
            "references/wiki-contract.md",
            "references/wiki-generated-document-read.md"
          ],
          "selectionPolicy": "optional-detail",
          "commandIntents": [
            "panel.selection.read",
            "wiki.document.list",
            "wiki.document.read"
          ]
        },
        {
          "key": "panel.wiki.document.generate",
          "description": "Generate a new standalone Wiki document through a target-bound Operation.",
          "panelKind": "wiki",
          "references": [
            "references/wiki-contract.md",
            "references/wiki-generated-documents.md"
          ],
          "selectionPolicy": "optional-detail",
          "commandIntents": [
            "wiki.document.generate",
            "operation.complete",
            "operation.fail",
            "operation.cancel"
          ]
        },
        {
          "key": "panel.wiki.document.revise",
          "description": "Revise an existing generated Wiki document through a target-bound Operation.",
          "panelKind": "wiki",
          "references": [
            "references/wiki-contract.md",
            "references/wiki-revise-generated-document.md"
          ],
          "selectionPolicy": "optional-detail",
          "commandIntents": [
            "panel.selection.read",
            "wiki.document.read",
            "wiki.document.generate",
            "operation.complete",
            "operation.fail",
            "operation.cancel"
          ]
        },
        {
          "key": "panel.wiki.document.publish",
          "description": "Publish an explicitly identified generated document into Wiki raw sources.",
          "panelKind": "wiki",
          "references": [
            "references/wiki-contract.md",
            "references/wiki-publish-generated-document.md"
          ],
          "selectionPolicy": "optional-detail",
          "commandIntents": [
            "panel.selection.read",
            "wiki.document.read",
            "wiki.document.publish"
          ]
        },
        {
          "key": "panel.wiki.document.delete",
          "description": "Delete an explicitly identified generated Wiki document.",
          "panelKind": "wiki",
          "references": [
            "references/wiki-contract.md",
            "references/wiki-delete-generated-document.md"
          ],
          "selectionPolicy": "optional-detail",
          "commandIntents": [
            "panel.selection.read",
            "wiki.document.list",
            "wiki.document.read",
            "wiki.document.delete"
          ]
        },
        {
          "key": "panel.wiki.space.manage",
          "description": "List, activate, or materialize a Wiki space.",
          "panelKind": "wiki",
          "references": [
            "references/wiki-contract.md",
            "references/wiki-space-management.md"
          ],
          "selectionPolicy": "none",
          "commandIntents": [
            "wiki.space.list",
            "wiki.space.activate",
            "wiki.space.materialize"
          ]
        },
        {
          "key": "panel.writing.context.read",
          "description": "Read the Writing panel's selected source and Wiki context.",
          "panelKind": "writing",
          "references": [
            "references/writing-contract.md",
            "references/writing-knowledge-context.md"
          ],
          "selectionPolicy": "active-detail",
          "commandIntents": [
            "panel.selection.read",
            "wiki.raw.read",
            "wiki.document.read",
            "wiki.space.materialize",
            "wiki.page.search",
            "wiki.page.read"
          ]
        }
      ],
      "taskHandoffs": [
        {
          "key": "panel.wiki.raw.convert",
          "description": "Convert an immutable raw source into faithful Markdown inside a claimed Task.",
          "panelKind": "wiki",
          "reference": "references/wiki-convert-document.md",
          "commandIntents": [
            "wiki.raw.read",
            "wiki.raw.update",
            "task.heartbeat",
            "task.complete",
            "task.fail"
          ]
        },
        {
          "key": "panel.wiki.pages.maintain",
          "description": "Maintain generated Wiki pages inside an exact claimed Task.",
          "panelKind": "wiki",
          "reference": "references/wiki-authoring-skill-routing.md",
          "commandIntents": [
            "agent.skill.read",
            "wiki.space.materialize",
            "wiki.page.search",
            "wiki.page.list",
            "wiki.page.read",
            "wiki.page.create",
            "wiki.page.update",
            "task.heartbeat",
            "task.complete",
            "task.fail"
          ]
        },
        {
          "key": "panel.writing.request.execute",
          "description": "Execute a submitted Writing request inside its claimed Task.",
          "panelKind": "writing",
          "reference": "references/writing-execute-request.md",
          "commandIntents": [
            "writing.request.read",
            "agent.skill.read",
            "writing.generate",
            "operation.complete",
            "task.complete",
            "task.fail"
          ]
        },
        {
          "key": "panel.writing.skill.refine",
          "description": "Refine selected examples into a reusable Writing Skill inside its claimed Task.",
          "panelKind": "writing",
          "reference": "references/writing-refine-skill.md",
          "commandIntents": [
            "writing.refinement.read",
            "agent.skill.read",
            "writing.skill.install",
            "task.complete",
            "task.fail"
          ]
        }
      ]
    },
    {
      "packageDir": "myopenpanels-task-queue",
      "id": "myopenpanels-task-queue",
      "name": "MyOpenPanels Task Queue",
      "source": "builtin",
      "appliesTo": ["any"],
      "taskTypes": [],
      "requiresCommands": [
        "task.list",
        "task.next",
        "task.read",
        "task.handoff.start",
        "task.handoff.exec",
        "task.handoff.heartbeat",
        "task.handoff.complete",
        "task.handoff.fail",
        "task.handoff.stop",
        "task.claim",
        "task.heartbeat",
        "task.complete",
        "task.fail",
        "task.events",
        "task.attempts",
        "workflow.run.read",
        "agent.bridge.run"
      ],
      "loadWhen": [
        "When the request handles work from the generic project Task queue."
      ],
      "tokens": "short",
      "procedures": [
        {
          "key": "task.queue.inspect",
          "description": "Inspect queued work, Task state, attempts, events, and its persisted Workflow Run.",
          "panelKind": null,
          "references": ["references/inspect.md"],
          "selectionPolicy": "none",
          "commandIntents": [
            "task.list",
            "task.next",
            "task.read",
            "task.events",
            "task.attempts",
            "workflow.run.read"
          ]
        },
        {
          "key": "task.queue.retry",
          "description": "Retry an explicitly identified failed Task.",
          "panelKind": null,
          "references": ["references/retry.md"],
          "selectionPolicy": "none",
          "commandIntents": ["task.read", "task.retry"]
        },
        {
          "key": "task.queue.cancel",
          "description": "Cancel an explicitly identified Task.",
          "panelKind": null,
          "references": ["references/cancel.md"],
          "selectionPolicy": "none",
          "commandIntents": ["task.read", "task.cancel"]
        },
        {
          "key": "task.queue.archive",
          "description": "Archive an explicitly identified terminal Task.",
          "panelKind": null,
          "references": ["references/archive.md"],
          "selectionPolicy": "none",
          "commandIntents": ["task.read", "task.archive"]
        }
      ],
      "taskHandoffs": [
        {
          "key": "task.scope.execute",
          "description": "Execute the exact Task scope supplied by a Studio handoff.",
          "panelKind": null,
          "reference": "references/execute-scope.md",
          "commandIntents": [
            "task.handoff.start",
            "task.handoff.exec",
            "task.handoff.heartbeat",
            "task.handoff.complete",
            "task.handoff.fail",
            "task.handoff.stop"
          ]
        }
      ]
    }
  ],
