{
  "name": "myopenpanels-monorepo",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "pnpm --dir apps/studio dev",
    "myopenpanels": "node scripts/myopenpanels-dev.mjs",
    "build": "pnpm -r build",
    "format": "ultracite fix",
    "lint": "ultracite check",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check:release": "node scripts/check-release-constraints.mjs",
    "package:release:cli": "node scripts/package-myopenpanels.mjs",
    "manifest:release:cli": "node scripts/generate-myopenpanels-release-manifest.mjs",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
